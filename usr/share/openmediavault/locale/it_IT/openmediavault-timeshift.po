msgid "Are you sure you want to delete this snapshot?"
msgstr "Sei sicuro di voler eliminare questo snapshot?"

msgid "Are you sure you want to revert to snapshot?"
msgstr "Sei sicuro di voler ripristinare questo snapshot?"

msgid "BTRFS mode"
msgstr ""

msgid "BTRFS mode requires the root filesystem (/) to be formatted as BTRFS."
msgstr ""

msgid ""
"BTRFS mode requires the root filesystem to be mounted as the '@' subvolume "
"(subvol=/@)."
msgstr ""

msgid "Backup destination device"
msgstr "Dispositivo di destinazione del backup"

msgid "Backup device"
msgstr "Dispositivo di backup"

msgid "Backup device needs to be set and applied!"
msgstr "È necessario impostare e applicare il dispositivo di backup!"

msgid "Boot"
msgstr "Boot"

msgid "Create snapshot"
msgstr "Crea snapshot"

msgid "Creating snapshot ..."
msgstr "Creazione dello snapshot in corso…"

msgid "Daily"
msgstr "Giornaliero"

msgid "Delete snapshot"
msgstr "Elimina snapshot"

msgid "Deleting snapshot ..."
msgstr "Eliminazione dello snapshot in corso…"

msgid "Description"
msgstr "Descrizione"

msgid "Device"
msgstr "Dispositivo"

msgid ""
"Enable when the OS root filesystem (/) is BTRFS and you want native BTRFS "
"snapshots stored on that same device. For protection against OS drive "
"failure, leave this disabled and use a separate backup device with RSYNC "
"mode."
msgstr ""

msgid "Excludes"
msgstr "Esclusioni"

msgid "Monthly"
msgstr "Mensile"

msgid "On-demand snapshots"
msgstr "Snapshot su richiesta"

msgid "Revert to snapshot"
msgstr "Ripristina snapshot"

msgid "Reverting to snapshot ..."
msgstr "Ripristino dello snapshot in corso…"

msgid "Scheduled snapshots"
msgstr "Snapshot pianificati"

msgid "Set to zero to disable"
msgstr "Imposta a zero per disabilitare"

msgid "Settings"
msgstr "Impostazioni"

msgid "Snapshot"
msgstr "Snapshot"

msgid "Stop cron email"
msgstr "Disabilita email cron"

msgid "Tags"
msgstr "Etichette"

msgid "This entry is used to create a snapshot only!"
msgstr "Questa voce serve solo a creare uno snapshot!"

msgid "Timeshift"
msgstr "Timeshift"

msgid ""
"Use , or ; or new line to separate entries.  Will be converted to comma "
"separated.<br/>Use trailing ** to match anything, including slashes.<br/>Use"
" trailing *** will match both the directory and everything in the "
"directory.<br/>See <a href='https://linux.die.net/man/1/rsync' "
"target=_blank>rsync manual</a> for additional explanation of "
"filters.<br/>Excludes are ignored in BTRFS mode."
msgstr ""

msgid "Weekly"
msgstr "Settimanale"

msgid "hourly"
msgstr "Ogni ora"
